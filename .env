# Telegram Bot Token (dapat dari @BotFather)
TELEGRAM_TOKEN=your_telegram_token_here

# DeepSeek API Key (dapat dari platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Admin Telegram ID (untuk admin commands)
ADMIN_ID=123456789

# Database
DB_PATH=data/gadis.db
MEMORY_DB_PATH=data/memory.db

# AI Settings
AI_TEMPERATURE=0.95
AI_MAX_TOKENS=600
AI_TIMEOUT=30

# Rate Limit
MAX_MESSAGES_PER_MINUTE=15
